VITE_API_BASE_URL=http://localhost:8000
VITE_WEB_APP_BASE_URL=http://localhost:3000
# Same Google OAuth client ID as the backend. The secret stays server-side.
# Register this redirect URI on the same Google OAuth client as the web app:
# http://localhost:3000/auth/extension/google/callback
# (Do NOT use /api/auth/callback/google — that route belongs to NextAuth.)
VITE_GOOGLE_CLIENT_ID=
